name: Deploy Sayyit.Web (Blazor WASM) to Azure Web App

on:
  push:
    branches: [env/dev]
    paths:
      - 'Sayyit.Web/**'
      - '.github/workflows/sayyit-web-action.yml'
  workflow_dispatch:

permissions:
  id-token: write
  contents: read

env:
  WEBAPP_NAME: sayyit-dev-web
  RESOURCE_GROUP: sayyit_rg1

jobs:
  build:
    runs-on: windows-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up .NET
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: '10.0.x'

      - name: Publish
        shell: pwsh
        run: dotnet publish Sayyit.Web\Sayyit.Web.csproj -c Release -o "$env:RUNNER_TEMP\myapp"

      - name: Verify publish output
        shell: pwsh
        run: |
          if (-not (Test-Path "$env:RUNNER_TEMP\myapp\web.config")) { throw "Missing web.config" }
          if (-not (Test-Path "$env:RUNNER_TEMP\myapp\wwwroot\index.html")) { throw "Missing index.html" }
          if ((Get-ChildItem "$env:RUNNER_TEMP\myapp\wwwroot\_framework" -Filter *.wasm -File).Count -lt 1) { throw "No wasm files" }
          if (Test-Path "$env:RUNNER_TEMP\myapp\wwwroot\web.config") { throw "Stray web.config inside wwwroot" }

      - name: Upload artifact
        uses: actions/upload-artifact@v4
        with:
          name: .net-app
          path: ${{ runner.temp }}/myapp

  deploy:
    runs-on: windows-latest
    needs: build
    steps:
      - name: Download artifact
        uses: actions/download-artifact@v4
        with:
          name: .net-app
          path: ${{ runner.temp }}/site

      - name: Azure login
        uses: azure/login@v2
        with:
          client-id: ${{ secrets.AZURE_CLIENT_ID }}
          tenant-id: ${{ secrets.AZURE_TENANT_ID }}
          subscription-id: ${{ secrets.AZURE_SUBSCRIPTION_ID }}

      - name: Zip payload
        shell: pwsh
        run: Compress-Archive -Path "${{ runner.temp }}/site/*" -DestinationPath "${{ runner.temp }}/app.zip" -Force

      - name: Deploy (clean)
        shell: pwsh
        run: |
          az webapp deploy `
            --resource-group "${{ env.RESOURCE_GROUP }}" `
            --name "${{ env.WEBAPP_NAME }}" `
            --src-path "${{ runner.temp }}/app.zip" `
            --type zip `
            --clean true `
            --restart true

      - name: Smoke test
        shell: pwsh
        run: |
          Start-Sleep -Seconds 20
          $r = Invoke-WebRequest "https://${{ env.WEBAPP_NAME }}.azurewebsites.net/" -UseBasicParsing
          if ($r.StatusCode -ne 200) { throw "Root returned $($r.StatusCode)" }