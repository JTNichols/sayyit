 
# Docs for the Azure Web Apps Deploy action: https://github.com/Azure/webapps-deploy
# More GitHub Actions for Azure: https://github.com/Azure/actions

name: ...WEBAPP...

on:
  push:
    branches:
      - env/dev
    paths:
      - 'Sayyit.Web/**'
      - '.github/workflows/sayyit-web-action.yml'
  workflow_dispatch:


permissions:
  id-token: write
  contents: read

env:
  RESOURCE_GROUP: sayyit_rg1
  ENV_NAME: dev
  BASE_NAME: sayyit
  WEBAPP_NAME: sayyit-dev-web
  KEYVAULT_NAME: sayyit-dev-kv
  KEYVAULT_SECRET_NAME: sayyit-dev-web-publish-profile

# Note: This workflow uses GitHub Actions OIDC federated credentials created by
# CreateEntraApp-ServPrinc-GhFedCred.ps1. Ensure the following repository
# secrets are set to the values the script printed:
#   AZURE_CLIENT_ID      -> Application (client) ID from the app registration
#   AZURE_TENANT_ID      -> Tenant ID
#   AZURE_SUBSCRIPTION_ID-> Subscription ID
# The workflow must have permissions.id-token: write (set above) and the push
# must come from the branch configured for the federated credential
# (refs/heads/env/dev).

jobs:
  build:
    runs-on: windows-latest
    permissions:
      contents: read #This is required for actions/checkout

    steps:
      - uses: actions/checkout@v4

      - name: Set up .NET Core
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: '10.0.x'

      - name: Restore
        run: dotnet restore Sayyit.Web\Sayyit.Web.csproj
        
      #- name: Build with dotnet
        #run: dotnet build Sayyit.Web\Sayyit.Web.csproj --configuration Release 

      - name: dotnet publish
        shell: pwsh
        run: dotnet publish Sayyit.Web\Sayyit.Web.csproj -c Release -o "$env:RUNNER_TEMP\myapp"
        #run: dotnet publish Sayyit.Web\Sayyit.Web.csproj -c Release -o "${{env.DOTNET_ROOT}}/myapp" --no-build

      - name: Verify processed index.html
        shell: pwsh
        run: |
          $index = Join-Path $env:RUNNER_TEMP "myapp\wwwroot\index.html"
          if (-not (Test-Path $index)) { throw "Published index.html not found: $index" }
          $content = Get-Content $index -Raw
          if ($content -match '#\[\.\{fingerprint\}\]') {
            throw "Fingerprint placeholder not replaced in index.html"
          }
          if ($content -notmatch '_framework/blazor\.webassembly\..+\.js') {
            throw "Processed blazor.webassembly fingerprinted script not found in published index.html"
          }

      - name: Verify framework runtime files
        shell: pwsh
        run: |
          $framework = Join-Path $env:RUNNER_TEMP "myapp\wwwroot\_framework"
          if (-not (Test-Path $framework)) { throw "_framework folder not found: $framework" }

          $wasmFiles = Get-ChildItem $framework -Filter *.wasm -File
          if (-not $wasmFiles -or $wasmFiles.Count -eq 0) {
            throw "No .wasm runtime files found in published _framework folder"
          }

          $bootJs = Get-ChildItem $framework -Filter "blazor.webassembly*.js" -File
          if (-not $bootJs) {
            throw "No blazor.webassembly boot script found in published _framework folder"
          }

      - name: Verify IIS web.config for wasm hosting
        shell: pwsh
        run: |
          $webConfig = Join-Path $env:RUNNER_TEMP "myapp\web.config"
          if (-not (Test-Path $webConfig)) { throw "Published web.config not found: $webConfig" }
          $content = Get-Content $webConfig -Raw
          if ($content -notmatch 'mimeMap fileExtension="\.wasm"') {
            throw "Published web.config is missing .wasm MIME mapping"
          }

      # - name: Copy web.config into deploy payload
      #   shell: pwsh
      #   run: Copy-Item "$env:RUNNER_TEMP\myapp\web.config" "$env:RUNNER_TEMP\myapp\wwwroot\web.config" -Force

      - name: Upload artifact for deployment job
        uses: actions/upload-artifact@v4
        with:
          name: .net-app
          path: ${{ runner.temp }}/myapp

  deploy:
    runs-on: windows-latest
    needs: build
    permissions:
      id-token: write
      contents: read
    
    steps:
      - name: Download artifact from build job
        uses: actions/download-artifact@v4
        with:
          name: .net-app
          path: ${{ runner.temp }}/site


      - name: Verify deploy payload
        shell: pwsh
        run: |
          if (-not (Test-Path "${{ runner.temp }}/site/web.config")) { throw "Missing web.config in deploy payload" }
          if (-not (Test-Path "${{ runner.temp }}/site/wwwroot/_framework")) { throw "Missing _framework in deploy payload" }
          $count = (Get-ChildItem "${{ runner.temp }}/site/wwwroot/_framework" -Filter *.wasm -File).Count
          if ($count -lt 1) { throw "No wasm files in deploy payload" }
          if (Test-Path "${{ runner.temp }}/site/wwwroot/web.config") { throw "Stray web.config inside wwwroot will break routing" }
           
      - name: Azure login
        uses: azure/login@v2
        with:
          client-id: ${{ secrets.AZURE_CLIENT_ID }}
          tenant-id: ${{ secrets.AZURE_TENANT_ID }}
          subscription-id: ${{ secrets.AZURE_SUBSCRIPTION_ID }}

      - name: Get publish profile from Key Vault
        id: get-publish-profile
        uses: azure/powershell@v2
        with:
          azPSVersion: latest
          inlineScript: |
            $publishProfile = az keyvault secret show `
              --vault-name "${{ env.KEYVAULT_NAME }}" `
              --name "${{ env.KEYVAULT_SECRET_NAME }}" `
              --query value -o tsv
            if ([string]::IsNullOrWhiteSpace($publishProfile)) {
              throw "Key Vault secret '${{ env.KEYVAULT_SECRET_NAME }}' was not found or is empty."
            }
            "publish_profile<<EOF" | Out-File -FilePath $env:GITHUB_OUTPUT -Encoding utf8 -Append
            $publishProfile | Out-File -FilePath $env:GITHUB_OUTPUT -Encoding utf8 -Append
            "EOF" | Out-File -FilePath $env:GITHUB_OUTPUT -Encoding utf8 -Append

      - name: Deploy to Azure Web App
        id: deploy-to-webapp
        uses: azure/webapps-deploy@v3
        with:
          app-name: ${{ env.WEBAPP_NAME }}
          slot-name: 'Production'
          package: ${{ runner.temp }}/site
          publish-profile: ${{ steps.get-publish-profile.outputs.publish_profile }}
      # - name: Deploy to Azure Web App
      #   shell: pwsh
      #   run: |
      #     az webapp deploy `
      #       --resource-group "${{ env.RESOURCE_GROUP }}" `
      #       --name "${{ env.WEBAPP_NAME }}" `
      #       --src-path "${{ runner.temp }}/site/wwwroot" `
      #       --type static `
      #       --clean true `
      #       --restart true
      #- name: Deploy to Azure Web App
        #id: deploy-to-webapp
        #uses: azure/webapps-deploy@v3
        #with:
          #app-name: ${{ env.WEBAPP_NAME }}
          #slot-name: 'Production'
          #package: ${{ runner.temp }}/site/wwwroot
          #publish-profile: ${{ steps.get-publish-profile.outputs.publish_profile }}
